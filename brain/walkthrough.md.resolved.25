@import "tailwindcss";

@theme {
  --color-background: #050505;
  --color-surface: #0e0e0e;
  --color-surface-hover: #141414;
  --color-card: #0a0a0a;
  --color-foreground: #ffffff;
  --color-muted: #808080;
  --color-primary: #E50914;
  --color-primary-hover: #f40a16;
  --color-primary-foreground: #ffffff;
  --color-accent: #E50914;
  --color-accent-foreground: #ffffff;
  --color-destructive: #ff0000;
  --color-border: rgba(255, 255, 255, 0.1);
  --color-input: rgba(255, 255, 255, 0.05);
  --color-ring: #E50914;

  --font-sans: var(--font-outfit), 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --font-display: var(--font-bebas-neue), 'Bebas Neue', cursive;

  --radius-sm: 4px;
  --radius-md: 6px;
  --radius-lg: 8px;
  --radius-xl: 12px;

  --spacing-header: 64px;
  --spacing-sidebar: 240px;
