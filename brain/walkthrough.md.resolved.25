    background-position: -200% 0;
  }
}

/* ═══════════════════════════════════════════
   PREMIUM UI ENHANCEMENTS (Apple/Google Style)
   ═══════════════════════════════════════════ */

.search-container {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-container:focus-within {
  background: rgba(255, 255, 255, 0.08);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4px rgba(229, 9, 20, 0.15);
}

.glass-panel {
  background: rgba(24, 24, 27, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  border-radius: var(--radius-xl);
}

.glow-border {
  position: relative;
}

.glow-border::before {
  content: "";
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(to bottom right, rgba(145, 71, 255, 0.5), rgba(0, 230, 203, 0.5));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.glow-border:hover::before {
  opacity: 1;
}

.btn-premium {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4px 12px rgba(145, 71, 255, 0.2);
  position: relative;
  overflow: hidden;
}

.btn-premium::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transform: skewX(-20deg);
  transition: left 0.5s ease;
}

.btn-premium:hover::after {
  left: 150%;
}

.btn-premium:hover {
  box-shadow: 0 6px 20px rgba(145, 71, 255, 0.4);
  transform: translateY(-1px);
}

/* ═══════════════════════════════════════════
   AUTH REDESIGN (Twitch/Apple Hybrid)
   ═══════════════════════════════════════════ */

.auth-card {
  background: var(--color-background);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.8),
    inset 0 1px 1px rgba(255, 255, 255, 0.03);
}

.auth-input-container {
  position: relative;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-md);
  transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
}

.auth-input-container:focus-within {
  background: rgba(255, 255, 255, 0.08);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4px rgba(229, 9, 20, 0.15);
}

.auth-input {
  width: 100%;
  background: transparent;
  padding: 1.25rem 1rem 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-foreground);
  border: none;
  border-radius: inherit;
  outline: none;
}

.auth-label {
  position: absolute;
  top: 50%;
  left: 1rem;
  transform: translateY(-50%);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-muted);
  pointer-events: none;
  transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
}

.auth-input:focus~.auth-label,
.auth-input:not(:placeholder-shown)~.auth-label {
  top: 0.35rem;
  transform: none;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
}

.auth-input:focus~.auth-label {
  color: var(--color-primary);
}

.google-btn-premium {
  background: #ffffff;
  color: #000000;
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: var(--radius-sm);
  font-weight: 700;
  font-size: 0.8125rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  height: 3.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.google-btn-premium:hover {
  background: #f9fafb;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  transform: translateY(-1px);
}

.google-btn-premium:active {
  transform: translateY(0);
}
