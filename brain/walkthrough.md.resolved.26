*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  -webkit-tap-highlight-color: transparent;
  scroll-behavior: smooth;
  font-size: 16px;
}

html,
body {
  background-color: var(--color-background);
  color: var(--color-foreground);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  min-height: 100vh;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
}

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.35);
}

a {
  color: inherit;
  text-decoration: none;
}

ul,
ol {
  list-style: none;
}

button {
  cursor: pointer;
  border: none;
  background: none;
  font-family: inherit;
  color: inherit;
}

input,
textarea,
select {
  font-family: inherit;
}

.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

/* ═══════════════════════════════════════════════
   LAYOUT SKELETON
   ═══════════════════════════════════════════════ */
.page-content {
  animation: fade-up 0.3s ease;
}

/* ═══════════════════════════════════════════════
   NAVBAR — YouTube-style
   ═══════════════════════════════════════════════ */
.yt-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: var(--spacing-header);
  background: var(--color-background);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  z-index: 100;
  padding: 0 16px;
  gap: 8px;
}

/* ═══════════════════════════════════════════════
   SIDEBAR — YouTube-style
   ═══════════════════════════════════════════════ */
.yt-sidebar {
  position: fixed;
  top: var(--spacing-header);
  left: 0;
  bottom: 0;
  overflow-y: auto;
  overflow-x: hidden;
  background: var(--color-background);
  z-index: 50;
  transition: width 0.2s ease;
}

.yt-sidebar.expanded {
  width: var(--spacing-sidebar);
}

.yt-sidebar.mini {
  width: var(--spacing-sidebar-mini);
}

.yt-sidebar.hidden-mobile {
  display: none;
}

@media (min-width: 1024px) {
  .yt-sidebar.hidden-mobile {
    display: flex;
    flex-direction: column;
  }
}

/* Nav item */
.sidebar-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 8px 12px;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 500;
  color: var(--color-foreground);
  cursor: pointer;
  transition: background 0.1s ease;
  white-space: nowrap;
  min-height: 40px;
}

.sidebar-item:hover {
  background: var(--color-surface);
}

.sidebar-item.active {
  background: var(--color-surface);
  font-weight: 600;
}

.sidebar-item.active .sidebar-icon {
  color: var(--color-primary);
}

.sidebar-item-mini {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  padding: 10px 0;
  font-size: 10px;
  font-weight: 500;
  color: var(--color-foreground);
  cursor: pointer;
  border-radius: var(--radius-md);
  transition: background 0.1s ease;
  min-height: 56px;
  width: 100%;
}

.sidebar-item-mini:hover {
  background: var(--color-surface);
}

.sidebar-item-mini.active {
  color: var(--color-primary);
}

.sidebar-item-mini.active .sidebar-icon {
  color: var(--color-primary);
}

.sidebar-section-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-foreground);
  padding: 12px 16px 8px;
  text-transform: capitalize;
}

.sidebar-divider {
  height: 1px;
  background: var(--color-border);
  margin: 8px 0;
}

/* ═══════════════════════════════════════════════
   SEARCH BAR — YouTube-style
   ═══════════════════════════════════════════════ */
.yt-search {
  display: flex;
  flex: 1;
  max-width: 600px;
  height: 40px;
}

.yt-search-input {
  flex: 1;
  background: var(--color-surface-input);
  border: 1px solid var(--color-border);
  border-right: none;
  border-radius: 40px 0 0 40px;
  padding: 0 16px;
  font-size: 16px;
  color: var(--color-foreground);
  outline: none;
  transition: border-color 0.2s;
}

.yt-search-input::placeholder {
  color: var(--color-muted);
}

.yt-search-input:focus {
  border-color: var(--color-border-focus);
  background: var(--color-background);
}

.yt-search-btn {
  width: 64px;
  height: 100%;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 0 40px 40px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-foreground);
  cursor: pointer;
  transition: background 0.15s;
  flex-shrink: 0;
}

.yt-search-btn:hover {
  background: var(--color-surface-2);
}

/* ═══════════════════════════════════════════════
   ICON BUTTONS — YouTube-style
   ═══════════════════════════════════════════════ */
.icon-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-foreground);
  cursor: pointer;
  transition: background 0.15s;
  flex-shrink: 0;
  background: none;
  border: none;
}

.icon-btn:hover {
  background: var(--color-surface);
}

/* ═══════════════════════════════════════════════
   BUTTONS — YouTube + Twitch + Apple style
   ═══════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 20px;
  height: 42px;
  /* Increased for better touch target */
  border-radius: 21px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
  font-family: inherit;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.5s;
}

.btn:hover::after {
  left: 100%;
}

.btn:active {
  transform: scale(0.96);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 4px 12px rgba(145, 71, 255, 0.25);
}

.btn-primary:hover {
  background: var(--color-primary-hover);
  box-shadow: 0 6px 16px rgba(145, 71, 255, 0.35);
}

.btn-secondary {
  background: var(--color-surface-2);
  color: var(--color-foreground);
}

.btn-secondary:hover {
  background: var(--color-surface-hover);
}

.btn-subscribe {
  background: var(--color-foreground);
  color: var(--color-background);
  font-weight: 700;
}

.btn-subscribe:hover {
  opacity: 0.9;
}

.btn-subscribed {
  background: var(--color-surface-2);
  color: var(--color-foreground);
}

.btn-outline {
  background: transparent;
  color: var(--color-foreground);
  border: 1px solid var(--color-border);
}

.btn-outline:hover {
  background: var(--color-surface);
  border-color: rgba(255, 255, 255, 0.2);
}

.btn-sm {
  height: 32px;
  padding: 0 16px;
  font-size: 13px;
  border-radius: 16px;
}

.btn-lg {
  height: 48px;
  padding: 0 28px;
  font-size: 16px;
  border-radius: 24px;
}

.btn-icon {
  padding: 0;
  width: 42px;
  height: 42px;
  border-radius: 50%;
}

/* ═══════════════════════════════════════════════
   VIDEO CARDS — YouTube-style (Optimized)
   ═══════════════════════════════════════════════ */
.video-card {
  cursor: pointer;
  display: flex;
  flex-direction: column;
  transition: transform 0.2s ease;
}

.video-thumbnail {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-surface);
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.video-thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease, filter 0.3s ease;
  display: block;
}

.video-card:hover .video-thumbnail img {
  transform: scale(1.03);
}

.video-duration {
  position: absolute;
  bottom: 6px;
  right: 6px;
  background: rgba(0, 0, 0, 0.85);
  color: #fff;
  font-size: 12px;
  font-weight: 600;
  padding: 2px 5px;
  border-radius: 4px;
  letter-spacing: 0.02em;
}

.video-live-badge {
  position: absolute;
  bottom: 6px;
  right: 6px;
  background: var(--color-live);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 4px;
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  gap: 4px;
}

.video-live-dot {
  width: 6px;
  height: 6px;
  background: #fff;
  border-radius: 50%;
  animation: pulse-live 1.5s ease infinite;
}

.video-views-live {
  position: absolute;
  bottom: 6px;
  left: 6px;
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 4px;
}

.video-meta {
  display: flex;
  gap: 12px;
  padding: 10px 0 4px;
}

.video-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-surface);
  margin-top: 2px;
}

.video-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-info {
  flex: 1;
  min-width: 0;
}

.video-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-foreground);
  line-height: 1.4;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4px;
  transition: color 0.15s;
}

.video-card:hover .video-title {
  color: var(--color-primary);
}

.video-author {
  font-size: 13px;
  color: var(--color-muted);
  font-weight: 400;
  display: flex;
  align-items: center;
  gap: 4px;
  transition: color 0.15s;
  margin-bottom: 2px;
}

.video-author:hover {
  color: var(--color-foreground);
}

.video-stats {
  font-size: 13px;
  color: var(--color-muted);
}

/* ═══════════════════════════════════════════════
   CHIP FILTERS — YouTube-style
   ═══════════════════════════════════════════════ */
.chip-bar {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 12px 0;
  scrollbar-width: none;
}

.chip-bar::-webkit-scrollbar {
  display: none;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 0 12px;
  height: 32px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.15s;
  background: var(--color-surface);
  color: var(--color-foreground);
  border: none;
  font-family: inherit;
}

.chip:hover {
  background: var(--color-surface-hover);
}

.chip.active {
  background: var(--color-foreground);
  color: var(--color-background);
}

/* ═══════════════════════════════════════════════
   FORM INPUTS 
   ═══════════════════════════════════════════════ */
.form-input {
  width: 100%;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-foreground);
  font-family: inherit;
  font-size: 15px;
  padding: 11px 14px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-input::placeholder {
  color: var(--color-muted);
}

.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-primary-light);
}

.form-input-icon {
  position: relative;
}

.form-input-icon .form-input {
  padding-left: 42px;
}

.form-input-icon .input-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-muted);
  pointer-events: none;
}

/* ═══════════════════════════════════════════════
   LIVE BADGE (sidebar channels)
   ═══════════════════════════════════════════════ */
.live-indicator {
  width: 8px;
  height: 8px;
  background: var(--color-live);
  border-radius: 50%;
  animation: pulse-live 1.5s ease infinite;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════
   SKELETON LOADING
   ═══════════════════════════════════════════════ */
.skeleton {
  background: linear-gradient(90deg, var(--color-surface) 25%, var(--color-surface-2) 50%, var(--color-surface) 75%);
  background-size: 400px 100%;
  animation: shimmer-load 1.4s ease infinite;
  border-radius: var(--radius-md);
}

/* ═══════════════════════════════════════════════
   VERIFIED BADGE
   ═══════════════════════════════════════════════ */
.verified-icon {
  color: #aaa;
  display: inline-flex;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════
   TWITCH-STYLE STREAM CARDS
   ═══════════════════════════════════════════════ */
.stream-card {
  cursor: pointer;
}

.stream-card:hover .video-thumbnail img {
  transform: scale(1.03);
}

/* ═══════════════════════════════════════════════
   BOTTOM NAV — Mobile
   ═══════════════════════════════════════════════ */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: rgba(15, 15, 15, 0.95);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  z-index: 100;
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--color-muted-2);
  transition: all 0.2s ease;
  font-size: 10px;
  font-weight: 500;
  cursor: pointer;
}

.bottom-nav-item.active {
  color: var(--color-foreground);
}

.bottom-nav-item:active {
  transform: scale(0.92);
  opacity: 0.8;
}

.create-btn-mobile {
  width: 44px;
  height: 32px;
  background: var(--color-primary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(145, 71, 255, 0.4);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.create-btn-mobile:active {
  transform: scale(0.9);
  background: var(--color-primary-hover);
}

/* ═══════════════════════════════════════════════
   VIDEO GRID
   ═══════════════════════════════════════════════ */
.video-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 16px 8px;
}

@media (min-width: 640px) {
  .video-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .video-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1280px) {
  .video-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (min-width: 1600px) {
  .video-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

/* ═══════════════════════════════════════════════
   ALERTS
   ═══════════════════════════════════════════════ */
.alert-error {
  background: rgba(239, 68, 68, 0.12);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #fca5a5;
  border-radius: var(--radius-md);
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ═══════════════════════════════════════════════
   DRAWER OVERLAY — Mobile sidebar
   ═══════════════════════════════════════════════ */
.drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 80;
}

.drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 240px;
  background: var(--color-background);
  z-index: 90;
  overflow-y: auto;
  transform: translateX(0);
  transition: transform 0.2s ease;
  padding-top: var(--spacing-header);
}

/* ═══════════════════════════════════════════════
   AUTH PAGES
   ═══════════════════════════════════════════════ */
.auth-card {
  background: var(--color-background);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 40px;
  width: 100%;
  max-width: 420px;
}

/* MISC */
.text-muted {
  color: var(--color-muted);
}

.text-muted-2 {
  color: var(--color-muted-2);
}

.text-primary {
  color: var(--color-primary);
}

.text-live {
  color: var(--color-live);
}

.divider {
  height: 1px;
  background: var(--color-border);
}
```
