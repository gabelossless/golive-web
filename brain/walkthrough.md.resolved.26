@import "tailwindcss";

@theme {
  /* ═══════════════════════════════════════════
     YOUTUBE × TWITCH DESIGN SYSTEM
     Dark, functional, content-first
     ═══════════════════════════════════════════ */

  /* Backgrounds (YouTube dark) */
  --color-background: #0f0f0f;
  --color-surface: #212121;
  --color-surface-2: #2f2f2f;
  --color-surface-hover: #3f3f3f;
  --color-surface-input: #121212;

  /* Text */
  --color-foreground: #f1f1f1;
  --color-muted: #aaaaaa;
  --color-muted-2: #717171;

  /* Primary: Twitch Purple */
  --color-primary: #9147ff;
  --color-primary-hover: #7d2ff7;
  --color-primary-light: rgba(145, 71, 255, 0.12);
  --color-primary-foreground: #ffffff;

  /* Accent: YouTube Red (for live + CTA only) */
  --color-live: #ef0000;
  --color-live-bg: rgba(239, 0, 0, 0.1);
  --color-success: #00b37e;
  --color-warning: #f59e0b;
  --color-destructive: #ef4444;

  /* Borders */
  --color-border: rgba(255, 255, 255, 0.08);
  --color-border-focus: rgba(145, 71, 255, 0.5);

  /* Layout */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-pill: 999px;

  --spacing-header: 56px;
  --spacing-sidebar: 240px;
  --spacing-sidebar-mini: 72px;

  /* Fonts */
  --font-sans: var(--font-roboto), 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;

  @keyframes pulse-live {

    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0.4;
    }
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes shimmer-load {
    0% {
      background-position: -400px 0;
    }

    100% {
      background-position: 400px 0;
    }
  }
}

/* ═══════════════════════════════════════════════
